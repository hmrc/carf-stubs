# microservice specific routes

POST        /dac6/dprs0102/v1                                      uk.gov.hmrc.carfstubs.controllers.RegistrationController.register()
POST        /dac6/dprs0101/v1                                      uk.gov.hmrc.carfstubs.controllers.RegistrationController.registerWithoutId()

GET         /dac6/ViewCarfSubscription/v1/:carfId                  uk.gov.hmrc.carfstubs.controllers.SubscriptionController.displaySubscription(carfId: String)
POST        /dac6/createsubscriptiondata/carf/v1                   uk.gov.hmrc.carfstubs.controllers.SubscriptionController.createSubscription()
PUT         /dac6/updatesubscriptiondata/carf/v1                   uk.gov.hmrc.carfstubs.controllers.SubscriptionController.updateSubscription()

PUT         /tax-enrolments/service/HMRC-CARF-ORG/enrolment        uk.gov.hmrc.carfstubs.controllers.EnrolmentController.upsertEnrolment

POST        /hmrc/email                                            uk.gov.hmrc.carfstubs.controllers.EmailController.send()

GET         /dac6/viewrcaspdata/v1/:carfId/:rcaspId                uk.gov.hmrc.carfstubs.controllers.RcaspController.viewRcasp(carfId: String, rcaspId: String)
POST        /dac6/SubmitRCASPData/v1                               uk.gov.hmrc.carfstubs.controllers.RcaspController.createRcasp
